# --- Hardware Setup ---
# Time button is on GPIO 5 (Physical Pin 29). DO NOT USE PIN 15.
BTN_OCR, BTN_OBJ, BTN_TIME, BTN_DIST, BTN_HELP = 27, 17, 5, 25, 26 
TRIG, ECHO = 23, 24

GPIO.setmode(GPIO.BCM)
GPIO.setwarnings(False)

for pin in [BTN_OCR, BTN_OBJ, BTN_TIME, BTN_DIST, BTN_HELP]:
    GPIO.setup(pin, GPIO.IN, pull_up_down=GPIO.PUD_UP)

GPIO.setup(TRIG, GPIO.OUT)
GPIO.setup(ECHO, GPIO.IN)

# --- Model Loading ---
PROTOTXT = "deploy.prototxt"
MODEL = "mobilenet_iter_73000.caffemodel"
CLASSES = ["background", "aeroplane", "bicycle", "bird", "boat", "bottle", "bus", "car", "cat", "chair", "cow", "diningtable", "dog", "horse", "motorbike", "person", "pottedplant", "sheep", "sofa", "train", "tvmonitor", "mobile phone"]
net = cv2.dnn.readNetFromCaffe(PROTOTXT, MODEL)

def speak(text, lang="en"):
    if not text.strip(): return
    print(f"Diya: {text}")
    tts = gTTS(text=text, lang=lang)
    tts.save("voice.mp3")
    subprocess.Popen(["mpg123", "-q", "voice.mp3"], stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)

def get_distance():
    GPIO.output(TRIG, True)
    time.sleep(0.00001)
    GPIO.output(TRIG, False)

    start_time = time.time()
    stop_time = time.time()
    timeout = time.time() + 1.0 

    while GPIO.input(ECHO) == 0 and time.time() < timeout:
        start_time = time.time()
    while GPIO.input(ECHO) == 1 and time.time() < timeout:
        stop_time = time.time()

    duration = stop_time - start_time
    distance = (duration * 34300) / 2
    return round(distance, 1)

def run_ocr(frame):
    print("Action: Enhanced OCR Scan...")
    cv2.imwrite("debug.jpg", frame) 
    
    h, w = frame.shape[:2]
    roi = frame[int(h*0.15):int(h*0.85), int(w*0.15):int(w*0.85)]
    gray = cv2.cvtColor(roi, cv2.COLOR_BGR2GRAY)
    
    kernel = np.array([[0, -1, 0], [-1, 5, -1], [0, -1, 0]])
    sharpened = cv2.filter2D(gray, -1, kernel)
    
    scaled = cv2.resize(sharpened, None, fx=2, fy=2, interpolation=cv2.INTER_LANCZOS4)
    text = pytesseract.image_to_string(scaled, lang="eng+hin+tel").strip()
    
    if text:
        hi = len(re.findall(r'[\u0900-\u097F]', text))
        te = len(re.findall(r'[\u0C00-\u0C7F]', text))
        lang = "te" if te > 5 else ("hi" if hi > 5 else "en")
        speak(text, lang)
    else:
        speak("No text detected.")

def run_vision(frame):
    print("Action: Object Detection...")
    cv2.imwrite("debug.jpg", frame) 
    
    blob = cv2.dnn.blobFromImage(cv2.resize(frame, (300, 300)), 0.007843, (300, 300), 127.5)
    net.setInput(blob)
    detections = net.forward()
    for i in range(detections.shape[2]):
        if detections[0, 0, i, 2] > 0.5:
            label = CLASSES[int(detections[0, 0, i, 1])]
            speak(f"I see a {label}")
            return
    speak("I am not sure what that is.")

def tell_time():
    print("Action: Telling Time...")
    now = datetime.now(pytz.timezone('Asia/Kolkata'))
    speak(f"India time is {now.strftime('%I:%M %p')}")

