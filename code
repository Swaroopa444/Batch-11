# --- Main Loop ---
cap = cv2.VideoCapture(0)
cap.set(cv2.CAP_PROP_BUFFERSIZE, 1) 
time.sleep(1) 
speak("Hello, I am Diya. I am online and ready.")

try:
    while True:
        ret, frame = cap.read()
        if not ret: continue

        if GPIO.input(BTN_OBJ) == GPIO.LOW:
            run_vision(frame)
            time.sleep(0.5)

        if GPIO.input(BTN_OCR) == GPIO.LOW:
            run_ocr(frame)
            time.sleep(0.5)

        if GPIO.input(BTN_TIME) == GPIO.LOW:
            tell_time()
            time.sleep(0.5)
            
        if GPIO.input(BTN_DIST) == GPIO.LOW:
            dist = get_distance()
            speak(f"Obstacle is {dist} centimeters away")
            time.sleep(0.5)

        if GPIO.input(BTN_HELP) == GPIO.LOW:
            press_start = time.time()
            is_emergency = False
            
            while GPIO.input(BTN_HELP) == GPIO.LOW:
                if time.time() - press_start > 3:
                    is_emergency = True
                    break
                    
            if is_emergency:
                provide_help(emergency=True)
            else:
                provide_help(emergency=False)
                
            time.sleep(0.5)

        time.sleep(0.05) 

except KeyboardInterrupt:
    pass
finally:
    GPIO.cleanup()
    cap.release()
